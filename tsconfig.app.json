{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict mode -- required by the course */
    "strict": true,

    /* Linting */
    // noUnusedLocals/noUnusedParameters off: GT1 keeps illustrative demo variables
    // erasableSyntaxOnly off: GT1 uses enums (SubmissionStatus, Role)
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
